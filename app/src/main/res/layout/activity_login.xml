<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/color_fondo_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER ROJO -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_header_height"
            android:background="@drawable/bg_header_red"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- CÍRCULO BLANCO -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="-25dp"
                android:background="@drawable/bg_circulo_blanco"
                android:elevation="6dp"/>

            <!-- LOGO -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="-18dp"
                android:elevation="8dp"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:padding="6dp"
                android:src="@drawable/fitmarket" />

            <!-- CURVA -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_gravity="bottom"
                android:scaleType="fitXY"
                android:src="@drawable/bg_header_curve_overlay"/>

        </FrameLayout>

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:text="@string/bienvenida_login"
            android:textSize="@dimen/text_title_size"
            android:textStyle="bold"
            android:textColor="@color/color_texto_principal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="@string/subtitulo_login"
            android:textSize="@dimen/text_subtitle_size"
            android:textColor="@color/color_texto_gris_claro" />

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/padding_screen"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TABS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tabLogin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingBottom="10dp"
                    android:text="@string/tab_iniciar_sesion"
                    android:textStyle="bold"
                    android:textColor="@color/color_rojo_principal" />

                <TextView
                    android:id="@+id/tabRegistro"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingBottom="10dp"
                    android:text="@string/tab_crear_cuenta"
                    android:textStyle="bold"
                    android:textColor="@color/color_texto_gris_claro" />

            </LinearLayout>

            <!-- EMAIL -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="@dimen/login_input_radius"
                app:boxCornerRadiusTopEnd="@dimen/login_input_radius"
                app:boxCornerRadiusBottomStart="@dimen/login_input_radius"
                app:boxCornerRadiusBottomEnd="@dimen/login_input_radius"
                app:startIconDrawable="@drawable/ic_mail"
                app:boxStrokeColor="@color/color_rojo_principal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_email"
                    android:inputType="textEmailAddress" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- PASSWORD -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="@dimen/login_input_radius"
                app:boxCornerRadiusTopEnd="@dimen/login_input_radius"
                app:boxCornerRadiusBottomStart="@dimen/login_input_radius"
                app:boxCornerRadiusBottomEnd="@dimen/login_input_radius"
                app:startIconDrawable="@drawable/ic_lock_small"
                app:endIconMode="password_toggle"
                app:boxStrokeColor="@color/color_rojo_principal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_password"
                    android:inputType="textPassword" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- OLVIDASTE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="@string/olvidaste_contrasena"
                android:textColor="@color/color_rojo_principal"
                android:textSize="12sp" />

            <!-- BOTON PRINCIPAL -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLoginPrincipal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/login_button_height"
                android:layout_marginTop="20dp"
                android:text="@string/boton_iniciar_sesion"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:cornerRadius="18dp"
                app:backgroundTint="@color/color_rojo_principal" />

            <!-- DIVIDER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:text="@string/continua_con"
                android:textColor="@color/color_texto_gris_claro"
                android:textSize="12sp" />

            <!-- BOTONES SOCIALES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- GOOGLE -->
                <LinearLayout
                    android:id="@+id/btnGoogle"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_google" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Google"
                        android:textColor="@color/color_texto_principal"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- TELEFONO -->
                <LinearLayout
                    android:id="@+id/btnTelefono"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_phone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Teléfono"
                        android:textColor="@color/color_texto_principal"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- APPLE -->
                <LinearLayout
                    android:id="@+id/btnApple"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_apple" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Apple"
                        android:textColor="@color/color_texto_principal"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- CAMBIAR MODO -->
        <TextView
            android:id="@+id/txtCambiarModo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="@string/no_tienes_cuenta"
            android:textColor="@color/color_texto_gris_claro"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>